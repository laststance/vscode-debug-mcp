{
  "name": "vscode-debug-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets AI agents control the VS Code debugger — breakpoints, stepping, call stacks, variables, and expression evaluation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vscode-debug-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "vscode",
    "debugger",
    "ai",
    "agent",
    "breakpoint",
    "claude",
    "cursor",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laststance/vscode-debug-mcp.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/laststance/vscode-debug-mcp/issues"
  },
  "homepage": "https://github.com/laststance/vscode-debug-mcp#readme",
  "scripts": {
    "build": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
