{
  "name": "vscode-debug-mcp-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Let AI agents drive the VS Code debugger — a VS Code extension (HTTP bridge) + MCP server pair",
  "license": "MIT",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "package": "pnpm --filter vscode-debug-mcp-bridge run package",
    "publish:stores": "pnpm run package && op run --env-file=.env.1password -- node scripts/publish-stores.mjs",
    "publish:stores:dry-run": "pnpm run package && node scripts/publish-stores.mjs --dry-run",
    "publish:npm": "pnpm --filter vscode-debug-mcp publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/laststance/vscode-debug-mcp.git"
  }
}
